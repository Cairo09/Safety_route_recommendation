# ============================================================
#  SafeRoute — Environment Variables Template
#  Copy this file to .env and fill in your actual values.
#  Never commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# ----------------------------------------------------------
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/saferoute

# ----------------------------------------------------------
# JWT signing secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------
SECRET_KEY=change-me-to-a-long-random-string

# JWT algorithm (HS256 is fine for most deployments)
ALGORITHM=HS256

# Token lifetime in hours (default 24)
ACCESS_TOKEN_EXPIRE_HOURS=24

# ----------------------------------------------------------
# CORS controls
# ----------------------------------------------------------
# Comma-separated allowed origins for browsers
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Set to 1 only for local experiments (unsafe for production)
ALLOW_ALL_CORS=0

# ----------------------------------------------------------
# API/Auth rate limits
# ----------------------------------------------------------
ROUTE_RATE_LIMIT=20/minute
AUTH_LOGIN_MAX_PER_MINUTE=20
AUTH_REGISTER_MAX_PER_MINUTE=10

# ----------------------------------------------------------
# Background issue cleanup
# ----------------------------------------------------------
ISSUE_CLEANUP_INTERVAL_MINUTES=30
# Set to 1 only for quick local prototyping. Prefer Alembic migrations.
AUTO_CREATE_TABLES=0

# ----------------------------------------------------------
# Routing and graph cache tuning
# ----------------------------------------------------------
ROUTING_SHORT_TRIP_UNSIMPLIFIED_MAX_M=2000
ROUTING_GRAPH_MIN_DIST_M=1500
ROUTING_GRAPH_MAX_DIST_M=8000
GRAPH_CACHE_MAX_ITEMS=20
GRAPH_CACHE_TTL_MINUTES=90
ROUTING_CACHE_CENTER_DECIMALS=1
# Preload city graphs to speed first route response after startup.
ROUTING_PRELOAD_ENABLED=1
# If 1, startup waits for preload completion (slower startup, fastest first route).
ROUTING_PRELOAD_BLOCKING=0
ROUTING_PRELOAD_DIST_M=8000
ROUTING_PRELOAD_MODES=walk,cycle,drive

# ----------------------------------------------------------
# Geoapify API key — sign up free at https://www.geoapify.com/
# ----------------------------------------------------------
GEOAPIFY_KEY=your_geoapify_api_key_here

# ----------------------------------------------------------
# Default map centre used as geocoding bias and map initial view.
# These coordinates are Bangalore, India.
# Change them if you deploy for a different city.
# ----------------------------------------------------------
DEFAULT_CITY_LAT=12.9716
DEFAULT_CITY_LON=77.5946
